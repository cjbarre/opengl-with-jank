#!/usr/bin/env bash
set -euo pipefail

# Build the jank-engine runtime binary: a single self-contained executable
# that AOT-bakes every engine.* namespace and bundles all native deps.
# Consumers run their games via:
#   jank-engine <game-dir> <namespace> [args...]

# Resolve symlinks to find actual script location
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
    SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

source "$SCRIPT_DIR/platform/common.sh"
require_platform_support
load_jank_paths

LIBS_DIR="$(get_libs_dir)"
LIB_EXT="$(get_lib_extension)"
BREW_PREFIX="$(get_homebrew_prefix)"

if [[ "$PLATFORM_OS" == "linux" ]]; then
    OPENGL_LIB_FLAG="-lGL -lGLEW"
    RPATH_PREFIX='$ORIGIN'
else
    OPENGL_LIB_FLAG="-lOpenGL"
    RPATH_PREFIX="@executable_path"
fi

NAMESPACE="engine.runtime.core"
OUTPUT="jank-engine"
# Per-binary dist tree so this doesn't clobber output of ./bin/compile
BUILD_DIR="$PROJECT_DIR/dist/jank-engine"

mkdir -p "$BUILD_DIR"

if [[ ! -f "$LIBS_DIR/engine-assets/lib/libengine_assets.$LIB_EXT" ]]; then
    echo "ERROR: libengine_assets.$LIB_EXT not found." >&2
    echo "       Run ./scripts/setup first." >&2
    exit 1
fi

export LIBRARY_PATH="$LIBS_DIR/glfw/lib:$LIBS_DIR/ozz-animation/lib:$LIBS_DIR/stb/lib:$LIBS_DIR/enet/lib:$LIBS_DIR/cgltf/lib:$LIBS_DIR/opengl/lib:$LIBS_DIR/engine-assets/lib:${LIBRARY_PATH:-}"

cd "$PROJECT_DIR"
if [[ "$PLATFORM_OS" == "linux" ]]; then
    GLFW_LIB="-lglfw"
else
    GLFW_LIB="-lglfw.3"
fi

jank \
  -I"$LIBS_DIR/glfw/include" -I"$PROJECT_DIR/libs/glm" -I"$PROJECT_DIR/include" -I"$LIBS_DIR/ozz-animation/include" \
  -L"$LIBS_DIR/glfw/lib" -L"$LIBS_DIR/ozz-animation/lib" -L"$LIBS_DIR/stb/lib" -L"$LIBS_DIR/enet/lib" -L"$LIBS_DIR/cgltf/lib" -L"$LIBS_DIR/opengl/lib" -L"$LIBS_DIR/engine-assets/lib" \
  $GLFW_LIB \
  -lozz_animation_r -lozz_base_r -lozz_geometry_r \
  -lstb_all \
  -lenet \
  -lcgltf \
  -lengine_assets \
  $OPENGL_LIB_FLAG \
  --module-path $(clojure -Spath) \
  compile "$NAMESPACE" -o "$BUILD_DIR/$OUTPUT"

# =============================================================================
# Bundle for standalone distribution
# =============================================================================
mkdir -p "$BUILD_DIR/bin"
mkdir -p "$BUILD_DIR/lib/$OUTPUT"
mkdir -p "$BUILD_DIR/lib/jank/0.1/bin"
mkdir -p "$BUILD_DIR/lib/jank/0.1/include"
mkdir -p "$BUILD_DIR/lib/jank/0.1/lib"
mkdir -p "$BUILD_DIR/lib/jank/0.1/src"

mv "$BUILD_DIR/$OUTPUT" "$BUILD_DIR/bin/$OUTPUT"

BUNDLE_DIR="$BUILD_DIR/lib/$OUTPUT"

# Game libraries
if [[ "$PLATFORM_OS" == "linux" ]]; then
    cp "$LIBS_DIR/glfw/lib/libglfw.so.3" "$BUNDLE_DIR/"
else
    cp "$LIBS_DIR/glfw/lib/libglfw.3.$LIB_EXT" "$BUNDLE_DIR/"
fi
cp "$LIBS_DIR/ozz-animation/lib/libozz_animation_r.$LIB_EXT" "$BUNDLE_DIR/"
cp "$LIBS_DIR/ozz-animation/lib/libozz_base_r.$LIB_EXT" "$BUNDLE_DIR/"
cp "$LIBS_DIR/ozz-animation/lib/libozz_geometry_r.$LIB_EXT" "$BUNDLE_DIR/"
cp "$LIBS_DIR/stb/lib/libstb_all.$LIB_EXT" "$BUNDLE_DIR/"
cp "$LIBS_DIR/enet/lib/libenet.$LIB_EXT" "$BUNDLE_DIR/"
cp "$LIBS_DIR/cgltf/lib/libcgltf.$LIB_EXT" "$BUNDLE_DIR/"
cp "$LIBS_DIR/engine-assets/lib/libengine_assets.$LIB_EXT" "$BUNDLE_DIR/"
if [[ "$PLATFORM_OS" == "macos" ]]; then
    cp "$LIBS_DIR/opengl/lib/libOpenGL.$LIB_EXT" "$BUNDLE_DIR/"
fi

# Jank/LLVM runtime libraries
if [[ "$PLATFORM_OS" == "linux" ]]; then
    # Bundle libLLVM/libclang-cpp/libc++/etc. The sources in $JANK_LLVM/lib/
    # are typically symlinks pointing into /lib/x86_64-linux-gnu/ (apt.llvm.org
    # layout splits dev symlinks from runtime files). `cp -dP` would preserve
    # those symlinks but they'd dangle on any other machine. So: resolve each
    # match to its real file, copy under the real (versioned) name, and add
    # a same-dir symlink for any alias the source had.
    bundle_versioned() {
        local src="$1"
        local dest_dir="$2"
        # Explicit `return 0` for missing matches: bare `return` returns the
        # last command's exit code (the failed [[ ]] test → 1), and a non-zero
        # function return aborts the caller under set -e. globs that don't
        # match (e.g. libc++ on system-Clang Linux) are normal, not errors.
        [[ -e "$src" || -L "$src" ]] || return 0
        local real
        real="$(readlink -f "$src")"
        [[ -f "$real" ]] || return 0
        local real_name
        real_name="$(basename "$real")"
        # Skip if we've already bundled this file (the apt deb ships
        # libLLVM.so → libLLVM.so.1 → libLLVM.so.22.1 as a symlink chain;
        # all three glob matches resolve to the same real file).
        # Also: don't create unversioned symlink aliases. The binary's
        # NEEDED entries reference the versioned soname directly, and
        # actions/upload-artifact dereferences any symlink in the zip,
        # turning each alias into a duplicate copy of the (~150 MB) file.
        if [[ ! -f "$dest_dir/$real_name" ]]; then
            cp -f "$real" "$dest_dir/$real_name"
        fi
    }
    for pat in libLLVM libclang-cpp libc++ libunwind libc++abi; do
        for src in "$JANK_LLVM/lib/${pat}".so*; do
            bundle_versioned "$src" "$BUNDLE_DIR"
        done
    done
    # libLLVM's transitive deps that aren't in /usr/lib/llvm-22/. libz3 is a
    # hard dep of LLVM 22 (used for SMT-based optimization passes); without
    # it the engine binary fails to start with "libz3.so.4 not found".
    for src in /usr/lib/x86_64-linux-gnu/libz3.so* /lib/x86_64-linux-gnu/libz3.so*; do
        bundle_versioned "$src" "$BUNDLE_DIR"
    done
else
    # macOS
    cp "$JANK_LLVM/lib/libLLVM.$LIB_EXT" "$BUNDLE_DIR/"
    cp "$JANK_LLVM/lib/libclang-cpp.$LIB_EXT" "$BUNDLE_DIR/"
    # libc++ / libc++abi / libunwind layout differs between LLVM sources:
    # - jank bundled LLVM (build-clang): everything in lib/
    # - brew llvm: libc++ family in lib/c++/, libunwind in lib/unwind/
    # Try both. The bundle ends up with the unversioned-prefix names
    # that the linker writes into the binary's NEEDED list (libc++.1).
    for pair in "libc++:lib/c++" "libc++abi:lib/c++" "libunwind:lib/unwind"; do
        libname="${pair%%:*}"
        subdir="${pair##*:}"
        for src in "$JANK_LLVM/lib/${libname}.1.0.$LIB_EXT" \
                   "$JANK_LLVM/${subdir}/${libname}.1.0.$LIB_EXT"; do
            if [[ -f "$src" ]]; then
                cp "$src" "$BUNDLE_DIR/${libname}.1.$LIB_EXT"
                break
            fi
        done
    done
fi

# System dependencies
if [[ "$PLATFORM_OS" == "macos" ]]; then
    bundle_system_lib "$BREW_PREFIX/opt/openssl@3/lib/libcrypto.3.$LIB_EXT" "$BUNDLE_DIR"
    bundle_system_lib "$BREW_PREFIX/opt/zstd/lib/libzstd.1.$LIB_EXT" "$BUNDLE_DIR"
elif [[ "$PLATFORM_OS" == "linux" ]]; then
    bundle_system_lib "/usr/lib/libcrypto.so.3" "$BUNDLE_DIR" 2>/dev/null || true
    bundle_system_lib "/usr/lib/libzstd.so.1" "$BUNDLE_DIR" 2>/dev/null || true
fi

# Clang executable (for JIT at runtime — needed for cpp/raw blocks AND the
# JIT-compile of consumer game source)
cp "$JANK_LLVM/bin/clang-22" "$BUILD_DIR/lib/jank/0.1/bin/"
ln -sf clang-22 "$BUILD_DIR/lib/jank/0.1/bin/clang++"
ln -sf clang-22 "$BUILD_DIR/lib/jank/0.1/bin/clang"

add_rpath "${RPATH_PREFIX}/../../../$OUTPUT" "$BUILD_DIR/lib/jank/0.1/bin/clang-22"

# Clang resource directory + C++ stdlib headers + jank stdlib.
# The destination must be mkdir'd FIRST: with `cp -R src/22 dest/clang/`
# where dest/clang/ doesn't exist, cp interprets dest/clang/ as the new
# name for the copied tree (i.e. dest/clang/include/, no `22/` level).
# That breaks clang's resource-dir auto-detection at runtime, which
# expects <bin>/../lib/clang/<MAJOR>/include/.
mkdir -p "$BUILD_DIR/lib/jank/0.1/lib/clang"
cp -R "$JANK_LLVM/lib/clang/22" "$BUILD_DIR/lib/jank/0.1/lib/clang/"

# C++ standard library headers — needed at runtime by the JIT for any
# game code that pulls in <vector>, <string>, etc. The bundled clang
# scans `<bin>/../include/c++/<version>` and picks it up automatically.
if [[ -d "$JANK_LLVM/include/c++" ]]; then
    # macOS (and Linux jank_local_clang=ON): libc++ ships under JANK_LLVM
    cp -R "$JANK_LLVM/include/c++" "$BUILD_DIR/lib/jank/0.1/include/"
elif [[ "$PLATFORM_OS" == "linux" ]]; then
    # Linux jank_local_clang=OFF: pull libstdc++ headers from the gcc-14
    # toolchain that jank was actually compiled against. Without this,
    # the bundle would silently fall back to whatever libstdc++ the host
    # has, which may be an older / incompatible version.
    #
    # Capture g++-14's verbose output to a variable first, then parse.
    # Piping into `awk '... ; exit'` triggers SIGPIPE upstream which
    # fails under pipefail+set-e.
    gcc_v_output="$(g++-14 -E -x c++ -v - </dev/null 2>&1 || true)"
    libstdcxx_root=""
    while IFS= read -r line; do
        if [[ "$line" =~ ^[[:space:]]+(/usr/include/c\+\+/[0-9]+)[[:space:]]*$ ]]; then
            libstdcxx_root="${BASH_REMATCH[1]}"
            break
        fi
    done <<<"$gcc_v_output"
    if [[ -n "$libstdcxx_root" && -d "$libstdcxx_root" ]]; then
        version="$(basename "$libstdcxx_root")"
        mkdir -p "$BUILD_DIR/lib/jank/0.1/include/c++"
        cp -R "$libstdcxx_root" "$BUILD_DIR/lib/jank/0.1/include/c++/"
        # Triple-specific bits (cxxabi, cpu_defines, etc.)
        triple_dir="/usr/include/$(uname -m)-linux-gnu/c++/$version"
        if [[ -d "$triple_dir" ]]; then
            mkdir -p "$BUILD_DIR/lib/jank/0.1/include/$(uname -m)-linux-gnu/c++"
            cp -R "$triple_dir" "$BUILD_DIR/lib/jank/0.1/include/$(uname -m)-linux-gnu/c++/"
        fi
    else
        echo "WARN: libstdc++ headers not found via g++-14; JIT may fall back to host headers" >&2
    fi
fi
cp -R "$JANK_DIR/include/cpp/jank" "$BUILD_DIR/lib/jank/0.1/include/"
cp -R "$JANK_DIR/src/jank/"* "$BUILD_DIR/lib/jank/0.1/src/"

# Fix rpaths in executable
if [[ "$PLATFORM_OS" == "macos" ]]; then
    change_lib_path "$BUILD_DIR/bin/$OUTPUT" "$BREW_PREFIX/opt/openssl@3/lib/libcrypto.3.$LIB_EXT" "@rpath/libcrypto.3.$LIB_EXT"
    change_lib_path "$BUILD_DIR/bin/$OUTPUT" "$BREW_PREFIX/opt/zstd/lib/libzstd.1.$LIB_EXT" "@rpath/libzstd.1.$LIB_EXT"
    change_lib_path "$BUILD_DIR/bin/$OUTPUT" "$BREW_PREFIX/opt/glfw/lib/libglfw.3.$LIB_EXT" "@rpath/libglfw.3.$LIB_EXT"
    # LLVM family. With jank_local_clang=OFF on macOS the binary's NEEDED
    # entries point at brew's absolute Cellar paths (libLLVM.dylib,
    # libclang-cpp.dylib, libc++.1.dylib in lib/c++/, libunwind.1.dylib in
    # lib/unwind/). Rewrite each to @rpath so the dyld lookup hits the
    # bundled copies in lib/<binary>/. Without this dyld fails before any
    # program output, smoke shows "::error::server failed to bind UDP/7777"
    # with an empty server.log.
    change_lib_path "$BUILD_DIR/bin/$OUTPUT" "$JANK_LLVM/lib/libLLVM.$LIB_EXT" "@rpath/libLLVM.$LIB_EXT"
    change_lib_path "$BUILD_DIR/bin/$OUTPUT" "$JANK_LLVM/lib/libclang-cpp.$LIB_EXT" "@rpath/libclang-cpp.$LIB_EXT"
    change_lib_path "$BUILD_DIR/bin/$OUTPUT" "$JANK_LLVM/lib/c++/libc++.1.$LIB_EXT" "@rpath/libc++.1.$LIB_EXT"
    change_lib_path "$BUILD_DIR/bin/$OUTPUT" "$JANK_LLVM/lib/unwind/libunwind.1.$LIB_EXT" "@rpath/libunwind.1.$LIB_EXT"
    change_lib_path "$BUILD_DIR/bin/$OUTPUT" "$JANK_LLVM/lib/c++/libc++abi.1.$LIB_EXT" "@rpath/libc++abi.1.$LIB_EXT"

    # Bundled dylibs themselves reference brew absolute paths in their own
    # load commands (libLLVM → libz3 / libc++; libclang-cpp → libLLVM; etc.).
    # Walk them, rewrite each absolute brew/Cellar reference to @rpath, AND
    # copy any not-yet-bundled dep into the bundle. Repeat until stable
    # (newly-bundled deps may themselves have brew references).
    process_macos_dylib_deps() {
        local dylib="$1"
        local added_count=0
        install_name_tool -id "@rpath/$(basename "$dylib")" "$dylib" 2>/dev/null || true
        while IFS= read -r dep; do
            case "$dep" in
                /opt/homebrew/*|/usr/local/Cellar/*|"$JANK_LLVM"/*)
                    local dep_name
                    dep_name="$(basename "$dep")"
                    if [[ ! -f "$BUNDLE_DIR/$dep_name" && -f "$dep" ]]; then
                        cp "$dep" "$BUNDLE_DIR/$dep_name"
                        chmod u+w "$BUNDLE_DIR/$dep_name"
                        added_count=$((added_count + 1))
                    fi
                    install_name_tool -change "$dep" "@rpath/$dep_name" "$dylib" 2>/dev/null || true
                    ;;
            esac
        done < <(otool -L "$dylib" | awk 'NR>1{print $1}')
        # Exit 0 if anything was added (so `if process_…; then` enters the body)
        [[ $added_count -gt 0 ]]
    }

    # Fixpoint: walk all bundled dylibs, then if any new files were added,
    # walk again. Cap at 5 iterations as a safety net.
    for _iter in 1 2 3 4 5; do
        any_added=0
        for dylib in "$BUNDLE_DIR"/*.dylib; do
            [[ -f "$dylib" ]] || continue
            if process_macos_dylib_deps "$dylib"; then
                any_added=1
            fi
        done
        [[ "$any_added" -eq 0 ]] && break
    done
fi

delete_rpath "$JANK_LLVM/bin/../lib" "$BUILD_DIR/bin/$OUTPUT"
add_rpath "${RPATH_PREFIX}/../lib/$OUTPUT" "$BUILD_DIR/bin/$OUTPUT"

# Re-sign every macOS Mach-O we modified. Each install_name_tool /
# add_rpath / delete_rpath call invalidates the ad-hoc signature
# Apple Clang stamps onto its outputs at link time, and macOS arm64
# SIGKILLs binaries with broken signatures (exit 137, no useful
# diagnostic). Without this pass, the CI artifact runs on the build
# runner — same security context, signature checks deferred — but
# fails immediately when a user downloads and unzips it elsewhere.
if [[ "$PLATFORM_OS" == "macos" ]]; then
    find "$BUILD_DIR" -type f \( -name '*.dylib' -o -name 'jank-engine' -o -name 'clang-22' \) \
      -print0 | xargs -0 codesign --force --sign - 2>/dev/null || true
fi

# Bundle headers next to the binary so consumer cpp/raw blocks can find
# glm, GLFW, ozz, engine/foo_impl.h, cgltf.h, etc. without anyone needing
# to know the build-machine paths. Runtime computes <bin-dir>/../include
# at startup and adds that to the JIT clang search path.
BUNDLE_INC="$BUILD_DIR/include"
mkdir -p "$BUNDLE_INC"
# Engine's own *_impl.h plus loose third-party headers
cp -R "$PROJECT_DIR/include/"* "$BUNDLE_INC/"
# GLM (header-only)
cp -R "$PROJECT_DIR/libs/glm/glm" "$BUNDLE_INC/"
# GLFW headers
if [[ -d "$LIBS_DIR/glfw/include/GLFW" ]]; then
    cp -R "$LIBS_DIR/glfw/include/GLFW" "$BUNDLE_INC/"
fi
# ozz-animation headers
if [[ -d "$LIBS_DIR/ozz-animation/include/ozz" ]]; then
    cp -R "$LIBS_DIR/ozz-animation/include/ozz" "$BUNDLE_INC/"
fi
# GLEW headers (Linux only — macOS uses Apple's OpenGL framework directly).
# The engine's gl_wrappers.h does `#include <GL/glew.h>` and the JIT needs
# to resolve that on the consumer machine without requiring libglew-dev to
# be installed there.
if [[ "$PLATFORM_OS" == "linux" ]]; then
    for cand in /usr/include/GL/glew.h /usr/include/GL/wglew.h /usr/include/GL/glxew.h; do
        if [[ -f "$cand" ]]; then
            mkdir -p "$BUNDLE_INC/GL"
            cp "$cand" "$BUNDLE_INC/GL/"
        fi
    done
fi

# Launcher (does NOT cd, so game paths resolve relative to user's CWD)
generate_launcher_script "$BUILD_DIR/${OUTPUT}_run" "bin/$OUTPUT" "lib/$OUTPUT"

echo ""
echo "============================================================================="
echo "Built: $BUILD_DIR/${OUTPUT}_run"
echo ""
echo "Try it on an existing example:"
echo "  $BUILD_DIR/${OUTPUT}_run \$(pwd) server     # uses jank-engine.edn"
echo ""
echo "Layout:"
echo "  dist/jank-engine/"
echo "  ├── bin/jank-engine          (executable)"
echo "  ├── lib/jank-engine/         (dylibs incl. libengine_assets)"
echo "  ├── lib/jank/0.1/            (jank runtime resources for JIT)"
echo "  └── jank-engine_run          (launcher)"
echo "============================================================================="
