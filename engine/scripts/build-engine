#!/usr/bin/env bash
set -euo pipefail

# Build the jank-engine dev runtime binary. This bundle intentionally depends
# on a compatible `jank` installation on PATH for LLVM/clang/JIT resources; it
# only packages the engine binary, engine-native dylibs, and headers needed by
# loose game source.

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
    SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

source "$SCRIPT_DIR/platform/common.sh"
require_platform_support
load_jank_paths

LIBS_DIR="$(get_libs_dir)"
LIB_EXT="$(get_lib_extension)"
BREW_PREFIX="$(get_homebrew_prefix)"

if [[ "$PLATFORM_OS" == "linux" ]]; then
    RPATH_PREFIX='$ORIGIN'
else
    RPATH_PREFIX="@executable_path"
fi

OUTPUT="jank-engine"
BUILD_DIR="$PROJECT_DIR/dist/jank-engine"
BUNDLE_DIR="$BUILD_DIR/lib/$OUTPUT"
BUNDLE_INC="$BUILD_DIR/include"

if [[ ! -f "$LIBS_DIR/engine-assets/lib/libengine_assets.$LIB_EXT" ]]; then
    echo "ERROR: libengine_assets.$LIB_EXT not found." >&2
    echo "       Run ./scripts/setup first." >&2
    exit 1
fi

chmod -R u+w "$BUILD_DIR" 2>/dev/null || true
rm -rf "$BUILD_DIR"
mkdir -p "$BUILD_DIR"

run_lein_compile_with_ozz_preload "$PROJECT_DIR"

mkdir -p "$BUILD_DIR/bin" "$BUNDLE_DIR" "$BUNDLE_INC"
mv "$BUILD_DIR/$OUTPUT" "$BUILD_DIR/bin/$OUTPUT"
rm -rf "$BUILD_DIR/_cache" "$BUILD_DIR/$OUTPUT.dSYM" "$BUILD_DIR/bin/$OUTPUT.dSYM"

# Engine-native dylibs. Jank/LLVM/clang dylibs are provided by the installed
# jank environment at runtime via the generated launcher.
if [[ "$PLATFORM_OS" == "linux" ]]; then
    cp "$LIBS_DIR/glfw/lib/libglfw.so.3" "$BUNDLE_DIR/"
else
    cp "$LIBS_DIR/glfw/lib/libglfw.3.$LIB_EXT" "$BUNDLE_DIR/"
fi
cp "$LIBS_DIR/ozz-animation/lib/libozz_animation_r.$LIB_EXT" "$BUNDLE_DIR/"
cp "$LIBS_DIR/ozz-animation/lib/libozz_base_r.$LIB_EXT" "$BUNDLE_DIR/"
cp "$LIBS_DIR/ozz-animation/lib/libozz_geometry_r.$LIB_EXT" "$BUNDLE_DIR/"
cp "$LIBS_DIR/stb/lib/libstb_all.$LIB_EXT" "$BUNDLE_DIR/"
cp "$LIBS_DIR/enet/lib/libenet.$LIB_EXT" "$BUNDLE_DIR/"
cp "$LIBS_DIR/cgltf/lib/libcgltf.$LIB_EXT" "$BUNDLE_DIR/"
cp "$LIBS_DIR/engine-assets/lib/libengine_assets.$LIB_EXT" "$BUNDLE_DIR/"
if [[ "$PLATFORM_OS" == "macos" ]]; then
    cp "$LIBS_DIR/opengl/lib/libOpenGL.$LIB_EXT" "$BUNDLE_DIR/"
fi

if [[ "$PLATFORM_OS" == "macos" ]]; then
    change_lib_path "$BUILD_DIR/bin/$OUTPUT" "$BREW_PREFIX/opt/glfw/lib/libglfw.3.$LIB_EXT" "@rpath/libglfw.3.$LIB_EXT"
    change_lib_path "$BUILD_DIR/bin/$OUTPUT" "$LIBS_DIR/glfw/lib/libglfw.3.$LIB_EXT" "@rpath/libglfw.3.$LIB_EXT"
    change_lib_path "$BUILD_DIR/bin/$OUTPUT" "$LIBS_DIR/opengl/lib/libOpenGL.$LIB_EXT" "@rpath/libOpenGL.$LIB_EXT"
    for dylib in "$BUNDLE_DIR"/*.dylib; do
        [[ -f "$dylib" ]] || continue
        install_name_tool -id "@rpath/$(basename "$dylib")" "$dylib" 2>/dev/null || true
    done
fi

add_rpath "${RPATH_PREFIX}/../lib/$OUTPUT" "$BUILD_DIR/bin/$OUTPUT"

if [[ "$PLATFORM_OS" == "macos" ]]; then
    find "$BUILD_DIR" -type f \( -name '*.dylib' -o -name "$OUTPUT" \) \
      -print0 | xargs -0 codesign --force --sign - 2>/dev/null || true
fi

# Headers consumed by loose game source at JIT time.
cp -R "$PROJECT_DIR/include/"* "$BUNDLE_INC/"
cp -R "$PROJECT_DIR/libs/glm/glm" "$BUNDLE_INC/"
if [[ -d "$LIBS_DIR/glfw/include/GLFW" ]]; then
    cp -R "$LIBS_DIR/glfw/include/GLFW" "$BUNDLE_INC/"
fi
if [[ -d "$LIBS_DIR/ozz-animation/include/ozz" ]]; then
    cp -R "$LIBS_DIR/ozz-animation/include/ozz" "$BUNDLE_INC/"
fi
if [[ "$PLATFORM_OS" == "linux" && -d /usr/include/GL ]]; then
    mkdir -p "$BUNDLE_INC/GL"
    cp -R /usr/include/GL/. "$BUNDLE_INC/GL/"
fi

cat > "$BUILD_DIR/${OUTPUT}_run" <<'LAUNCHER'
#!/usr/bin/env bash
set -euo pipefail

DIR="$(cd "$(dirname "$0")" && pwd)"

if ! command -v jank >/dev/null 2>&1; then
    echo "ERROR: jank-engine requires a compatible jank installation on PATH." >&2
    exit 1
fi

JANK_BIN="$(command -v jank)"
if command -v realpath >/dev/null 2>&1; then
    JANK_BIN="$(realpath "$JANK_BIN" 2>/dev/null || echo "$JANK_BIN")"
elif command -v readlink >/dev/null 2>&1; then
    JANK_BIN="$(readlink -f "$JANK_BIN" 2>/dev/null || echo "$JANK_BIN")"
fi

if [[ "$JANK_BIN" == */build/jank ]]; then
    JANK_DIR="${JANK_BIN%/build/jank}"
else
    JANK_DIR="$(cd "$(dirname "$JANK_BIN")/.." && pwd)"
fi

JANK_LLVM="${JANK_LLVM:-}"
if [[ -z "$JANK_LLVM" && -d "$JANK_DIR/build/llvm-install/usr/local" ]]; then
    JANK_LLVM="$JANK_DIR/build/llvm-install/usr/local"
elif [[ -z "$JANK_LLVM" && -d /opt/homebrew/opt/llvm ]]; then
    JANK_LLVM="/opt/homebrew/opt/llvm"
elif [[ -z "$JANK_LLVM" && -d /usr/local/opt/llvm ]]; then
    JANK_LLVM="/usr/local/opt/llvm"
elif [[ -z "$JANK_LLVM" && -d /usr/lib/llvm-22 ]]; then
    JANK_LLVM="/usr/lib/llvm-22"
fi

if [[ -z "$JANK_LLVM" || ! -d "$JANK_LLVM/lib" ]]; then
    echo "ERROR: unable to locate installed jank LLVM libraries." >&2
    echo "       Set JANK_LLVM to the LLVM root used by your jank install." >&2
    exit 1
fi

if [[ "$(uname -s)" == "Darwin" ]]; then
    # Do not prepend the installed jank LLVM/C++ runtime on macOS. The engine
    # binary is linked with jank's own rpaths; overriding them through
    # DYLD_LIBRARY_PATH can mix incompatible C++ runtime images.
    DYLD_LIBRARY_PATH="$DIR/lib/jank-engine${DYLD_LIBRARY_PATH:+:$DYLD_LIBRARY_PATH}" \
      exec "$DIR/bin/jank-engine" "$@"
else
    LIB_PATHS=("$DIR/lib/jank-engine" "$JANK_LLVM/lib")
    LD_LIBRARY_PATH="$(IFS=:; echo "${LIB_PATHS[*]}")${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}" \
      exec "$DIR/bin/jank-engine" "$@"
fi
LAUNCHER
chmod +x "$BUILD_DIR/${OUTPUT}_run"

echo ""
echo "============================================================================="
echo "Built: $BUILD_DIR/${OUTPUT}_run"
echo ""
echo "Requires a compatible jank install on PATH for LLVM/clang/JIT resources."
echo ""
echo "Try it on an existing game:"
echo "  cd ../game"
echo "  ../engine/dist/jank-engine/${OUTPUT}_run . server"
echo ""
echo "Layout:"
echo "  dist/jank-engine/"
echo "  ├── bin/jank-engine          (executable)"
echo "  ├── lib/jank-engine/         (engine-native dylibs)"
echo "  ├── include/                 (headers for game cpp/raw)"
echo "  └── jank-engine_run          (launcher)"
echo "============================================================================="
