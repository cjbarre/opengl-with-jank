#!/bin/bash
# Test the entire animation pipeline:
# 1. Convert a single animation with debug output
# 2. Run viewer and capture debug
# 3. Compare converter output vs viewer output

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
GLA_EXTRACT_DIR="${GLA_EXTRACT_DIR:-/tmp/gla-extract}"
CONVERTER_OUTPUT="${CONVERTER_OUTPUT:-/tmp/converter-output.txt}"
CONVERTED_ANIM="${CONVERTED_ANIM:-/tmp/BOTH_STAND1.ozz}"
CONVERTED_SKEL="${CONVERTED_SKEL:-/tmp/humanoid.ozz}"
cd "$PROJECT_DIR"

echo "=== ANIMATION PIPELINE TEST ==="
echo ""

# Step 1: Make sure GLA is extracted
GLA_FILE="$GLA_EXTRACT_DIR/models/players/_humanoid/_humanoid.gla"
if [ ! -f "$GLA_FILE" ]; then
    echo "Step 1: Extracting GLA file..."
    echo "NOTE: You need to extract the GLA file from your source to $GLA_EXTRACT_DIR/"
    exit 1
fi

# Step 2: Convert with debug output
echo "Step 2: Converting BOTH_STAND1 with debug..."
"$PROJECT_DIR/tools/gla2ozz/build/gla2ozz" \
    --file="$GLA_FILE" \
    --config_file="$PROJECT_DIR/tools/gla2ozz/test_stand1_only.json" 2>&1 \
    | tee "$CONVERTER_OUTPUT"

# Step 3: Copy converted files
echo ""
echo "Step 3: Copying converted files..."
cp "$CONVERTED_ANIM" "$CONVERTED_SKEL" "$PROJECT_DIR/models/player/animations/"

# Step 4: Extract key data from converter
echo ""
echo "=== CONVERTER OUTPUT ANALYSIS ==="
echo ""
echo "--- SKELETON pelvis local rotation ---"
grep -A5 "SKELETON Joint\[1\]" "$CONVERTER_OUTPUT" | grep "OZZ local rot"

echo ""
echo "--- ANIMATION pelvis local rotation ---"
grep -A6 "ANIMATION Joint\[1\]" "$CONVERTER_OUTPUT" | grep "Computed local rot"

echo ""
echo "--- ANIMATION pelvis world position ---"
grep -A2 "ANIMATION Joint\[1\]" "$CONVERTER_OUTPUT" | grep "OZZ world pos"

echo ""
echo "=== KEY COMPARISON ==="
echo ""
echo "For a STAND animation, pelvis rotation should be similar to rest pose."
echo "Small differences are normal (weight shifting, breathing)."
echo "Large differences suggest a bug in the conversion."
echo ""

# Extract the actual values for comparison
SKEL_ROT=$(grep -A5 "SKELETON Joint\[1\]" "$CONVERTER_OUTPUT" | grep "OZZ local rot" | sed 's/.*(\([^)]*\)).*/\1/')
ANIM_ROT=$(grep -A6 "ANIMATION Joint\[1\]" "$CONVERTER_OUTPUT" | grep "Computed local rot" | sed 's/.*(\([^)]*\)).*/\1/')

echo "Skeleton pelvis OZZ rot: ($SKEL_ROT)"
echo "Animation pelvis OZZ rot: ($ANIM_ROT)"
echo ""
echo "Full converter output saved to: $CONVERTER_OUTPUT"
